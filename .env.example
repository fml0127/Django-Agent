VISION_API_KEY=
VISION_MAX_PDF_PAGES=5
VISION_IMAGE_DPI=144
VISION_PARSE_MAX_TOKENS=2048

LIBREOFFICE_BINARY=soffice
DOCUMENT_CONVERSION_TIMEOUT_SECONDS=60
