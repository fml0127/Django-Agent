# ── 应用配置 ────────────────────────────────────────────────────────
APP_NAME=个人轻量知识库

# ── 阿里云百炼（DashScope）配置 ─────────────────────────────────────
DASHSCOPE_API_KEY=
ALIYUN_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
ALIYUN_BAILIAN_CHAT_MODEL=qwen3.6-flash
ALIYUN_BAILIAN_SUMMARY_MODEL=qwen3.6-flash
ALIYUN_BAILIAN_TITLE_MODEL=qwen3.6-flash
ALIYUN_BAILIAN_QUESTION_MODEL=qwen3.6-flash
ALIYUN_BAILIAN_EXTRACT_MODEL=qwen3.6-flash
ALIYUN_BAILIAN_EMBEDDING_MODEL=text-embedding-v4
ALIYUN_BAILIAN_EMBEDDING_DIM=1024
ALIYUN_BAILIAN_RERANK_MODEL=qwen3-rerank
ALIYUN_BAILIAN_VLM_MODEL=qwen-vl-plus
ALIYUN_BAILIAN_ASR_MODEL=paraformer-v2
ALIYUN_BAILIAN_ASR_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/audio/transcriptions

# 是否使用百炼模型（true/false）
WEKNORA_USE_BAILIAN_CHAT=true
WEKNORA_USE_BAILIAN_SUMMARY=true
WEKNORA_USE_BAILIAN_TITLE=true
WEKNORA_USE_BAILIAN_QUESTION=true
WEKNORA_USE_BAILIAN_EXTRACT=true
WEKNORA_USE_BAILIAN_EMBEDDING=false
WEKNORA_USE_BAILIAN_RERANK=true
WEKNORA_USE_BAILIAN_VLM=true
WEKNORA_USE_BAILIAN_ASR=true
WEKNORA_EMBEDDING_DIM=384

# ── Neo4j 配置（知识图谱 + 记忆系统）────────────────────────────────
# 需要先启动 Neo4j：docker run -d --name neo4j -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j:5-community
NEO4J_ENABLE=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ── Langfuse 可观测性（可选）─────────────────────────────────────────
# 注册 https://cloud.langfuse.com 获取 key
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── 任务配置 ─────────────────────────────────────────────────────────
# 后台任务线程数（默认 4）
# WEKNORA_TASK_WORKERS=4

# ── SQLite 配置 ──────────────────────────────────────────────────────
# 数据库锁等待超时（秒，默认 30）
# SQLITE_TIMEOUT=30
