# ── Django 安全配置 ──────────────────────────────────────────────────
# 生产环境必须设置以下变量
# DJANGO_SECRET_KEY=your-secret-key-here
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# 开发环境默认值（生产环境请注释掉）
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── 应用配置 ────────────────────────────────────────────────────────
APP_NAME=个人轻量知识库

# ── LLM 对话模型 ────────────────────────────────────────────────────
# 支持任意 OpenAI 兼容接口（OpenAI、DeepSeek、Ollama、vLLM、阿里云百炼等）
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_CHAT_MODEL=qwen3.6-flash

# ── LLM 摘要/标题/问题生成/抽取模型（通常与对话模型相同）─────────────
LLM_SUMMARY_MODEL=qwen3.6-flash
LLM_TITLE_MODEL=qwen3.6-flash
LLM_QUESTION_MODEL=qwen3.6-flash
LLM_EXTRACT_MODEL=qwen3.6-flash

# ── Embedding 模型 ──────────────────────────────────────────────────
# 可以使用不同提供商的 Embedding 模型
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_EMBEDDING_MODEL=text-embedding-v4
LLM_EMBEDDING_DIM=1024

# ── Rerank 模型 ─────────────────────────────────────────────────────
LLM_RERANK_API_KEY=
LLM_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_RERANK_MODEL=qwen3-rerank

# ── VLM 视觉模型（可选）────────────────────────────────────────────
LLM_VLM_API_KEY=
LLM_VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VLM_MODEL=qwen-vl-plus

# ── ASR 语音识别模型（可选）─────────────────────────────────────────
LLM_ASR_API_KEY=
LLM_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_ASR_MODEL=paraformer-v2
LLM_ASR_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/audio/transcriptions

# ── Neo4j 配置（知识图谱 + 记忆系统）────────────────────────────────
# 需要先启动 Neo4j：docker run -d --name neo4j -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j:5-community
NEO4J_ENABLE=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ── Langfuse 可观测性（可选）─────────────────────────────────────────
# 注册 https://cloud.langfuse.com 获取 key
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── 任务配置 ─────────────────────────────────────────────────────────
# 后台任务线程数（默认 4）
# WEKNORA_TASK_WORKERS=4

# ── SQLite 配置 ──────────────────────────────────────────────────────
# 数据库锁等待超时（秒，默认 30）
# SQLITE_TIMEOUT=30

# ── 日志级别 ─────────────────────────────────────────────────────────
# DJANGO_LOG_LEVEL=INFO
